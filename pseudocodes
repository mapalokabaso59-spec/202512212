# Factorial function
def factorial(n):
    result = 1
    for i in range(1, n + 1):
        result *= i
    return result


# Fibonacci function
def fibonacci(n):
    a, b = 0, 1
    for _ in range(n):
        print(a, end=" ")
        a, b = b, a + b


# Main program
num = int(input("Enter a number: "))

print("\nFactorial:", factorial(num))

print("Fibonacci sequence:")
fibonacci(num)